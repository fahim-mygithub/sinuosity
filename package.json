{
  "name": "sinuosity",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "description": "WNY motorcycle ride finder — twisty, scenic backroad scoring from 36 Char Del Way",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "scenic:gather": "node scripts/gather-scenic.mjs",
    "scenic:discover": "node scripts/discover-roads.mjs",
    "scenic:snap": "node scripts/snap-streetview.mjs",
    "scenic:assemble": "node scripts/assemble-scenic.mjs",
    "scenic:recurate": "node scripts/recurate-scenic.mjs",
    "scenic:verify": "node scripts/verify-roads.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.3"
  }
}
